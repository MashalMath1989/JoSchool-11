rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Connectivity test - allow all access to test path
    match /test/{any=**} {
      allow read, write: if true;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             (data.completedLessons is list || !data.keys().hasAll(['completedLessons'])) &&
             (data.quizResults is list || !data.keys().hasAll(['quizResults'])) &&
             (data.favoriteQuestions is list || !data.keys().hasAll(['favoriteQuestions'])) &&
             (data.totalTimeSpent is number || !data.keys().hasAll(['totalTimeSpent'])) &&
             (data.lastActive is string || !data.keys().hasAll(['lastActive']));
    }

    match /users/{userId} {
      allow read: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
